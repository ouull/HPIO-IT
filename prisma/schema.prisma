generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String        @id @default(cuid())
  email      String        @unique
  password   String
  name       String
  roleId     String
  role       Role          @relation(fields: [roleId], references: [id])
  employee   Employee?
  activities ActivityLog[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique // "Admin", "User"
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id        String              @id @default(cuid())
  userId    String?             @unique
  user      User?               @relation(fields: [userId], references: [id])
  name      String
  position  String
  period    String
  photoUrl  String?
  history   InternshipHistory[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model InternshipHistory {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  position    String
  startDate   DateTime
  endDate     DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  station   String
  building  String
  floor     String
  assets    Asset[]
  systems   System[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id         String    @id @default(cuid())
  name       String
  category   String    // "Equipment", "Tools", "Sparepart"
  condition  String
  status     String
  lastMaint  DateTime?
  locationId String
  location   Location  @relation(fields: [locationId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model System {
  id         String   @id @default(cuid())
  name       String   // "TVM", "CCTV", "X-Ray", "PIDS", "Gate System"
  function   String
  status     String
  docUrl     String?
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SOP {
  id        String   @id @default(cuid())
  title     String
  version   String
  category  String
  fileUrl   String
  changes   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  targetType String   // e.g., "Asset", "System"
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())
}
